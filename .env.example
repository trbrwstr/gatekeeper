# Required: JWT signing secret. Must be at least 32 characters of
# high-entropy randomness (the app refuses to start otherwise, and rejects
# this placeholder value). Generate one with: openssl rand -base64 48
GATEKEEPER_JWT_SECRET=change-me-to-a-strong-random-secret

# Required if no [[users]] are defined in config.toml
GATEKEEPER_ADMIN_USER=admin
GATEKEEPER_ADMIN_PASS=change-me-to-a-strong-password

# Required only in multi-node mode (central/node): shared secret nodes use to
# authenticate to the central gRPC server. Must be at least 16 characters.
GATEKEEPER_CLUSTER_TOKEN=change-me-to-a-shared-cluster-secret

# Optional: address the central-mode gRPC server binds to. Defaults to
# 127.0.0.1:<port+1>. Set to 0.0.0.0:8081 to accept remote nodes.
# GATEKEEPER_GRPC_ADDR=0.0.0.0:8081
